 }
 .service-card .icon { color: var(--primary); display: inline-flex; flex-shrink: 0; }
 .service-card .icon svg { display: block; }
@@ -295,7 +295,7 @@ textarea.input-field { resize: none; min-height: 150px; }
 .addon-card:hover { border-color: rgba(123, 89, 0, 0.2); }
 .addon-card.selected {
     border-color: #000000;
-    background-color: #FFFDF4;
+    background-color: #FFFFFF;
 }
 .addon-card .icon { color: var(--primary); display: inline-flex; }
 .addon-card .icon svg { display: block; width: 28px; height: 28px; }
