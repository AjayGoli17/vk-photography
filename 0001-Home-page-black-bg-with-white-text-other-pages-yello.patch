     --on-surface: #1b1c1c;
     --on-surface-variant: #4e4637;
@@ -241,7 +241,7 @@ textarea.input-field { resize: none; min-height: 150px; }
 .service-card:hover { border-color: rgba(123, 89, 0, 0.5); }
 .service-card.selected {
     border: 2px solid #000000;
-    background-color: #FFFDF4;
