From: Ajay Goli <ajay@example.com>
Date: Sat, 18 Jul 2026 10:00:11 +0000
Subject: [PATCH] Home page: black bg with white text; other pages:
 yellow/cream shades to pure white

---
 css/contact.css   |  8 ++++----
 css/home.css      | 45 +++++++++++++++++++++++++++++++--------------
 css/portfolio.css |  4 ++--
 css/quotation.css |  6 +++---
 css/service.css   |  6 +++---
 css/style.css     |  6 +++---
 6 files changed, 46 insertions(+), 29 deletions(-)

diff --git a/css/contact.css b/css/contact.css
index 5c7a98b..139fc13 100644
--- a/css/contact.css
+++ b/css/contact.css
@@ -5,7 +5,7 @@
 }
 
 :root {
-    --bg-color: #FFFDF4;
+    --bg-color: #FFFFFF;
     --text-main: #2B2620;
     --text-muted: #7A7566;
     --accent: #B08D57;
@@ -39,7 +39,7 @@ a {
     align-items: center;
     text-align: center;
     padding: 0 2rem;
-    background: radial-gradient(circle at center, #F4EFDF 0%, #FFFDF4 70%);
+    background: radial-gradient(circle at center, #FFFFFF 0%, #FFFFFF 70%);
 }
 
 .hero h1 {
@@ -108,7 +108,7 @@ a {
 
 /* --- Form --- */
 .form-panel {
-    background-color: #F4EFDF;
+    background-color: #FFFFFF;
     border: 1px solid rgba(43, 38, 32, 0.08);
     border-radius: 6px;
     padding: 3rem;
@@ -342,7 +342,7 @@ a {
     aspect-ratio: 4 / 3;
     border: 1px solid rgba(43, 38, 32, 0.12);
     overflow: hidden;
-    background: #F4EFDF;
+    background: #FFFFFF;
 }
 
 .map-embed iframe {
diff --git a/css/home.css b/css/home.css
index de3b779..3913436 100644
--- a/css/home.css
+++ b/css/home.css
@@ -1,6 +1,23 @@
 /* NOTE: :root variables, reset, nav, mobile sidebar, and footer
      now live in style.css. Link style.css BEFORE this file. */
 
+  /* ---------- HOME PAGE THEME OVERRIDE: black bg, white text ----------
+     Redeclares the shared tokens from style.css. Since home.css is only
+     linked on index.html, this only affects the home page — every other
+     page keeps the white theme from style.css untouched. */
+  :root {
+    --cream: #000000;
+    --ink: #FFFFFF;
+    --gray: #B7B3AA;
+    --line: rgba(255,255,255,0.16);
+    --card: #141414;
+    --accent-bg-light: #0D0D0D;
+    --accent-bg-deep: #1A1A1A;
+    --border-subtle: rgba(255,255,255,0.12);
+    --border-default: rgba(255,255,255,0.16);
+    --border-strong: rgba(255,255,255,0.24);
+  }
+
   /* ---------- HERO ---------- */
   .hero {
     position: relative;
@@ -109,8 +126,8 @@
     transform: translateY(-3px);
     gap: 18px;
     background: transparent;
-    border-color: #000;
-    color: #000;
+    border-color: var(--ink);
+    color: var(--ink);
   }
 
   .hero-cta svg { width: 16px; height: 16px; }
@@ -300,8 +317,8 @@
   .services-cta:hover {
     transform: translateY(-3px);
     background: transparent;
-    border-color: #000;
-    color: #000;
+    border-color: var(--ink);
+    color: var(--ink);
   }
 
   .services-head p {
@@ -695,7 +712,7 @@
     position: absolute;
     bottom: -20px;
     right: -20px;
-    background: #ffffff;
+    background: var(--card);
     border-radius: 12px;
     padding: 14px 20px;
     box-shadow: 0 4px 16px rgba(0,0,0,0.08);
@@ -839,7 +856,7 @@
   }
   .tc-card{
     position:absolute;top:50%;left:50%;width:340px;padding:30px 28px;
-    background:var(--ink);
+    background:#141414;
     border:1px solid rgba(255,255,255,.16);
     border-radius:22px;color:#fff;
     box-shadow:
@@ -872,16 +889,16 @@
   .tc-controls{display:flex;align-items:center;gap:18px}
   .tc-nav-btn{
     width:40px;height:40px;border-radius:50%;
-    background:rgba(43,38,32,.06);
-    border:1px solid rgba(43,38,32,.18);
+    background:rgba(255,255,255,.06);
+    border:1px solid rgba(255,255,255,.18);
     backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
     color:var(--ink);font-size:16px;cursor:pointer;
     display:flex;align-items:center;justify-content:center;
     transition:background .2s;
   }
-  .tc-nav-btn:hover{background:rgba(43,38,32,.14)}
+  .tc-nav-btn:hover{background:rgba(255,255,255,.14)}
   .tc-dots{display:flex;gap:8px}
-  .tc-dot{width:7px;height:7px;border-radius:50%;background:rgba(43,38,32,.3);
+  .tc-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.3);
        cursor:pointer;transition:background .2s,transform .2s;border:none;padding:0}
   .tc-dot.active{background:var(--ink);transform:scale(1.3)}
 
@@ -900,11 +917,11 @@
     margin-bottom:12px;
   }
   .tc-section-divider{
-    width:60px;height:1px;background:rgba(43,38,32,.2);
+    width:60px;height:1px;background:rgba(255,255,255,.25);
     margin:8px 0 4px;
   }
   .tc-eyebrow{
-    font-size:14px;letter-spacing:.08em;color:rgba(43,38,32,.55);
+    font-size:14px;letter-spacing:.08em;color:rgba(255,255,255,.6);
     font-family:Georgia,serif;font-style:italic;margin-bottom:18px;
   }
   .tc-headline{
@@ -943,7 +960,7 @@
     .tc-headline-img{border-radius:10px}
   }
   .tc-subtext{
-    font-size:16px;color:rgba(43,38,32,.6);margin-bottom:30px;
+    font-size:16px;color:rgba(255,255,255,.6);margin-bottom:30px;
   }
   .tc-cta-btn{
     display:inline-block;
@@ -956,4 +973,4 @@
     cursor:pointer;
     transition:background .2s, border-color .2s, color .2s, transform .2s;
   }
-  .tc-cta-btn:hover{background:transparent; border-color:#000; color:#000; transform: translateY(-3px);}
\ No newline at end of file
+  .tc-cta-btn:hover{background:transparent; border-color:var(--ink); color:var(--ink); transform: translateY(-3px);}
\ No newline at end of file
