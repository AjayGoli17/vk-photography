                    text += `\n\nMessage: ${message}`;
                }

                const url = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`;

                submitButton.classList.add('is-loading');
                submitButton.querySelector('.btn-label').textContent = 'Opening whatsapp';
                submitButton.disabled = true;

                setTimeout(() => {
                    window.open(url, '_blank');
                    submitButton.classList.remove('is-loading');
                    submitButton.querySelector('.btn-label').textContent = 'Book your shoot';
                    submitButton.disabled = false;
                }, 500);
            });
        });
    </script>

</body>
</html>


:root {
    --cream: #0a0a0a;
    --ink: #f4f1e9;
    --gray: #a8a299;
    --line: rgba(244,241,233,0.22);
    --nav-h: 84px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  a { color: inherit; text-decoration: none; }

  /* ---------- NAV ---------- */
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    z-index: 100;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Fraunces', serif;
    font-size: 19px;
    letter-spacing: 0.06em;
  }

  .logo-text {
    font-weight: 500;
  }

  nav.links {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  nav.links a {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.75;
    transition: opacity 0.25s ease;
  }
  nav.links a:hover { opacity: 1; }

  .menu-btn { display: none; background: none; border: none; font-size: 22px; cursor: pointer; color: var(--ink); }

  /* ---------- MOBILE SIDEBAR ---------- */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(29,26,22,0.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    z-index: 199;
  }

  .sidebar-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: min(78vw, 320px);
    background: var(--cream);
    z-index: 200;
    display: flex;
    flex-direction: column;
    padding: 24px 28px 40px;
    transform: translateX(100%);
    transition: transform 0.45s cubic-bezier(.2,.8,.2,1);
    box-shadow: -20px 0 50px rgba(29,26,22,0);
  }

  .sidebar.is-open {
    transform: translateX(0);
    box-shadow: -20px 0 50px rgba(29,26,22,0.18);
  }

  .sidebar-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 56px;
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: 30px;
    line-height: 1;
    color: var(--ink);
    cursor: pointer;
    padding: 4px;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-links a {
    font-family: 'Fraunces', serif;
    font-size: 26px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .sidebar.is-open .sidebar-links a {
    opacity: 1;
    transform: translateY(0);
  }

  .sidebar.is-open .sidebar-links a:nth-child(1) { transition-delay: 0.12s; }
  .sidebar.is-open .sidebar-links a:nth-child(2) { transition-delay: 0.18s; }
  .sidebar.is-open .sidebar-links a:nth-child(3) { transition-delay: 0.24s; }
  .sidebar.is-open .sidebar-links a:nth-child(4) { transition-delay: 0.3s; }

  body.no-scroll { overflow: hidden; }

  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    z-index: 1;
    background: var(--cream);
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 160px 24px 90px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, rgba(201,138,59,0.16) 0%, rgba(201,138,59,0) 65%);
    transform: translate(-50%, -50%);
    pointer-events: none;
    animation: glowPulse 8s ease-in-out infinite;
    z-index: 0;
  }

  @keyframes glowPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.7; }
    50% { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
  }

  .hero-eyebrow, .hero h1, .hero-cta, .scroll-hint {
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 22px;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.1s;
  }

  .hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(38px, 6.4vw, 82px);
    line-height: 1.12;
    max-width: 980px;
    letter-spacing: -0.01em;
  }

  .hero h1 em {
    font-style: italic;
    font-weight: 500;
  }

  .word {
    display: inline-block;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(22px);
    animation: wordReveal 0.9s cubic-bezier(.2,.65,.3,1) forwards;
  }

  @keyframes wordReveal {
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }

  .hero-cta {
    margin-top: 44px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    background: transparent;
    border: 1px solid var(--ink);
    color: var(--ink);
    padding: 17px 30px;
    border-radius: 100px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 1.1s;
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1), gap 0.3s ease, box-shadow 0.35s ease, background 0.35s ease, color 0.35s ease;
  }

  .hero-cta:hover {
    transform: translateY(-3px);
    gap: 18px;
    background: var(--ink);
    color: var(--cream);
    box-shadow: 0 14px 34px rgba(244,241,233,0.14);
  }

  .hero-cta svg { width: 16px; height: 16px; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .scroll-hint {
    margin-top: 64px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 1.3s, bob 2.2s ease-in-out infinite 2s;
  }

  .scroll-hint::after {
    content: '';
    width: 1px;
    height: 32px;
    background: var(--gray);
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ---------- PORTFOLIO — sits right against the hero, no gap ---------- */
  .portfolio {
    position: relative;
    z-index: 1;
    background: var(--cream);
    padding: 0 48px 120px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 110px;
    grid-auto-flow: dense;
    gap: 18px;
  }

  .tile {
    position: relative;
    overflow: hidden;
    background: #ded8ca;
    cursor: pointer;
    opacity: 0;
    transform: translateY(46px) scale(0.94);
    filter: blur(14px);
    transition: opacity 0.9s cubic-bezier(.16,.84,.44,1),
                transform 0.9s cubic-bezier(.16,.84,.44,1),
                filter 0.9s cubic-bezier(.16,.84,.44,1);
  }

  .tile.in-view {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.18);
    transition: transform 1s cubic-bezier(.16,.84,.44,1);
  }

  .tile.in-view img { transform: scale(1); }

  .tile:hover img { transform: scale(1.07); }

  .tile-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(29,26,22,0) 45%, rgba(29,26,22,0.85) 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 18px;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .tile:hover .tile-overlay { opacity: 1; }

  .tile-overlay .tag {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #d8a45a;
    margin-bottom: 4px;
  }

  .tile-overlay .title {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    color: #f2efe8;
  }

  .tile.t1 { grid-column: span 2; grid-row: span 3; }
  .tile.t2 { grid-column: span 2; grid-row: span 2; }
  .tile.t3 { grid-column: span 2; grid-row: span 2; }
  .tile.t4 { grid-column: span 2; grid-row: span 2; }
  .tile.t5 { grid-column: span 2; grid-row: span 3; }
  .tile.t6 { grid-column: span 2; grid-row: span 2; }
  .tile.t7 { grid-column: span 4; grid-row: span 2; }
  .tile.t8 { grid-column: span 2; grid-row: span 2; }
  .tile.t9 { grid-column: span 2; grid-row: span 3; }
  .tile.t10 { grid-column: span 4; grid-row: span 2; }

  /* ---------- SERVICES (auto-scrolling slider) ---------- */
  .services {
    position: relative;
    z-index: 1;
    background: var(--cream);
    padding: 100px 0 130px;
    border-top: 1px solid var(--line);
  }

  .services-head {
