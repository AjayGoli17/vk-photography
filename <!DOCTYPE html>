  }

  /* Hybrid mobile layout: most photos run full-width in a single
     column for impact; every so often two are paired side-by-side
     for rhythm/variety. Built by JS below. */
  .masonry {
    display: none;
    flex-direction: column;
    gap: 16px;
  }

  .pair-row {
    display: flex;
    gap: 12px;
