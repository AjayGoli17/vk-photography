  /* ---------- TESTIMONIALS (merged from sample1.html, classes namespaced with tc- to avoid collisions) ---------- */
  .testimonials-section{
    position:relative;
    z-index:1;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
