  /* ---------- ABOUT ---------- */
  .about-section {
    position: relative;
    z-index: 1;
    background: var(--cream);
    display: flex;
    width: 100%;
    max-width: 100vw;
    padding: 100px 48px 120px;
    align-items: stretch;
