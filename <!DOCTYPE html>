  .description [data-su] {
    display: block;
    margin-bottom: 16px;
  }
  .description [data-su]:last-child { margin-bottom: 0; }

  /* Line-mask reveal: each heading line slides up from behind an
     overflow-hidden mask, staggered line by line */
  .about-line-mask { display: block; overflow: hidden; }
  .about-line-inner {
    display: block;
    transform: translateY(105%);
    transition: transform 0.7s cubic-bezier(0.22,1,0.36,1);
