<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aperture &amp; Co. — A Photography Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #0a0a0a;
    --ink: #f4f1e9;
    --gray: #a8a299;
    --line: rgba(244,241,233,0.22);
    --nav-h: 84px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  a { color: inherit; text-decoration: none; }

  /* ---------- NAV ---------- */
  header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    z-index: 100;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Fraunces', serif;
    font-size: 19px;
    letter-spacing: 0.06em;
  }

  .logo-text {
    font-weight: 500;
  }

  nav.links {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  nav.links a {
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.75;
    transition: opacity 0.25s ease;
  }
  nav.links a:hover { opacity: 1; }

  .menu-btn { display: none; background: none; border: none; font-size: 22px; cursor: pointer; color: var(--ink); }

  /* ---------- MOBILE SIDEBAR ---------- */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(29,26,22,0.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    z-index: 199;
  }

  .sidebar-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .sidebar {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: min(78vw, 320px);
    background: var(--cream);
    z-index: 200;
    display: flex;
    flex-direction: column;
    padding: 24px 28px 40px;
    transform: translateX(100%);
    transition: transform 0.45s cubic-bezier(.2,.8,.2,1);
    box-shadow: -20px 0 50px rgba(29,26,22,0);
  }

  .sidebar.is-open {
    transform: translateX(0);
    box-shadow: -20px 0 50px rgba(29,26,22,0.18);
  }

  .sidebar-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 56px;
  }

  .sidebar-close {
    background: none;
    border: none;
    font-size: 30px;
    line-height: 1;
    color: var(--ink);
    cursor: pointer;
    padding: 4px;
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-links a {
    font-family: 'Fraunces', serif;
    font-size: 26px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .sidebar.is-open .sidebar-links a {
    opacity: 1;
    transform: translateY(0);
  }

  .sidebar.is-open .sidebar-links a:nth-child(1) { transition-delay: 0.12s; }
  .sidebar.is-open .sidebar-links a:nth-child(2) { transition-delay: 0.18s; }
  .sidebar.is-open .sidebar-links a:nth-child(3) { transition-delay: 0.24s; }
  .sidebar.is-open .sidebar-links a:nth-child(4) { transition-delay: 0.3s; }

  body.no-scroll { overflow: hidden; }

  /* ---------- HERO ---------- */
  .hero {
    position: relative;
    z-index: 1;
    background: var(--cream);
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 160px 24px 90px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, rgba(201,138,59,0.16) 0%, rgba(201,138,59,0) 65%);
    transform: translate(-50%, -50%);
    pointer-events: none;
    animation: glowPulse 8s ease-in-out infinite;
    z-index: 0;
  }

  @keyframes glowPulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.7; }
    50% { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
  }

  .hero-eyebrow, .hero h1, .hero-cta, .scroll-hint {
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 22px;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.1s;
  }

  .hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(38px, 6.4vw, 82px);
    line-height: 1.12;
    max-width: 980px;
    letter-spacing: -0.01em;
  }

  .hero h1 em {
    font-style: italic;
    font-weight: 500;
  }

  .word {
    display: inline-block;
    opacity: 0;
    filter: blur(10px);
    transform: translateY(22px);
    animation: wordReveal 0.9s cubic-bezier(.2,.65,.3,1) forwards;
  }

  @keyframes wordReveal {
    to { opacity: 1; filter: blur(0); transform: translateY(0); }
  }

  .hero-cta {
    margin-top: 44px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    background: transparent;
    border: 1px solid var(--ink);
    color: var(--ink);
    padding: 17px 30px;
    border-radius: 100px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 1.1s;
    transition: transform 0.35s cubic-bezier(.2,.8,.2,1), gap 0.3s ease, box-shadow 0.35s ease, background 0.35s ease, color 0.35s ease;
  }

  .hero-cta:hover {
    transform: translateY(-3px);
    gap: 18px;
    background: var(--ink);
    color: var(--cream);
    box-shadow: 0 14px 34px rgba(244,241,233,0.14);
  }

  .hero-cta svg { width: 16px; height: 16px; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .scroll-hint {
    margin-top: 64px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 1.3s, bob 2.2s ease-in-out infinite 2s;
  }

  .scroll-hint::after {
    content: '';
    width: 1px;
    height: 32px;
    background: var(--gray);
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ---------- PORTFOLIO — sits right against the hero, no gap ---------- */
  .portfolio {
    position: relative;
    z-index: 1;
    background: var(--cream);
    padding: 0 48px 120px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 110px;
    grid-auto-flow: dense;
    gap: 18px;
  }

  .tile {
    position: relative;
    overflow: hidden;
    background: #ded8ca;
    cursor: pointer;
    opacity: 0;
    transform: translateY(46px) scale(0.94);
    filter: blur(14px);
    transition: opacity 0.9s cubic-bezier(.16,.84,.44,1),
                transform 0.9s cubic-bezier(.16,.84,.44,1),
                filter 0.9s cubic-bezier(.16,.84,.44,1);
  }

  .tile.in-view {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }

  .tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.18);
    transition: transform 1s cubic-bezier(.16,.84,.44,1);
  }

  .tile.in-view img { transform: scale(1); }

  .tile:hover img { transform: scale(1.07); }

  .tile-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(29,26,22,0) 45%, rgba(29,26,22,0.85) 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 18px;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .tile:hover .tile-overlay { opacity: 1; }

  .tile-overlay .tag {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #d8a45a;
    margin-bottom: 4px;
  }

  .tile-overlay .title {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    color: #f2efe8;
  }

  .tile.t1 { grid-column: span 2; grid-row: span 3; }
  .tile.t2 { grid-column: span 2; grid-row: span 2; }
  .tile.t3 { grid-column: span 2; grid-row: span 2; }
  .tile.t4 { grid-column: span 2; grid-row: span 2; }
  .tile.t5 { grid-column: span 2; grid-row: span 3; }
  .tile.t6 { grid-column: span 2; grid-row: span 2; }
  .tile.t7 { grid-column: span 4; grid-row: span 2; }
  .tile.t8 { grid-column: span 2; grid-row: span 2; }
  .tile.t9 { grid-column: span 2; grid-row: span 3; }
  .tile.t10 { grid-column: span 4; grid-row: span 2; }

  /* ---------- SERVICES (auto-scrolling slider) ---------- */
  .services {
    position: relative;
    z-index: 1;
    background: var(--cream);
    padding: 100px 0 130px;
    border-top: 1px solid var(--line);
  }

  .services-head {
    padding: 90px 48px 50px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }

  .services-head .overline {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: var(--gray);
    text-transform: uppercase;
    margin-bottom: 22px;
  }

  .services-head h2 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(30px, 4.4vw, 50px);
    line-height: 1.15;
    max-width: 640px;
    letter-spacing: -0.01em;
  }

  .services-head-right {
    display: flex;
    align-items: flex-end;
    gap: 28px;
  }

  .services-head p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--gray);
    max-width: 260px;
    padding-bottom: 6px;
  }

  .slider-nav {
    display: flex;
    gap: 10px;
    flex: 0 0 auto;
  }

  .slider-nav button {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .slider-nav button:hover {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--cream);
    transform: translateY(-2px);
  }

  .slider-nav button svg { width: 17px; height: 17px; }

  .slider-viewport {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 64px, #000 calc(100% - 64px), transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0, #000 64px, #000 calc(100% - 64px), transparent 100%);
  }

  .slider-track {
    display: flex;
    width: max-content;
    gap: 22px;
    padding: 4px 48px;
    will-change: transform;
  }

  .service-card {
    position: relative;
    flex: 0 0 auto;
    width: 340px;
    height: 440px;
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
  }

  .service-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.06);
    transition: transform 0.9s cubic-bezier(.16,.84,.44,1);
  }

  .service-card:hover img { transform: scale(1); }

  .service-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(29,26,22,0) 62%, rgba(29,26,22,0.55) 100%);
    transition: background 0.4s ease;
  }

  .service-card .card-info {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 22px 22px;
    color: #f2efe8;
    z-index: 1;
  }

  .service-card .num {
    display: block;
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 12px;
    color: #d8a45a;
    margin-bottom: 6px;
    letter-spacing: 0.02em;
  }

  .service-card h3 {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: 19px;
    letter-spacing: -0.01em;
    text-shadow: 0 1px 12px rgba(0,0,0,0.25);
  }

  .service-card p {
    font-size: 12.5px;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(242,239,232,0.88);
    max-width: 90%;
    margin-top: 8px;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.35s ease, margin-top 0.4s ease;
  }

  .service-card:hover p {
    max-height: 80px;
    opacity: 1;
  }

  .service-card:hover::after {
    background: linear-gradient(180deg, rgba(29,26,22,0) 30%, rgba(29,26,22,0.82) 100%);
  }

  @media (max-width: 900px) {
    .services-head { flex-direction: column; align-items: flex-start; padding: 60px 20px 28px; gap: 18px; }
    .services-head-right { width: 100%; justify-content: space-between; }
    .services-head p { max-width: 100%; }
    .slider-track { padding: 4px 20px; }
    .service-card { width: 76vw; height: 400px; }
    .slider-viewport { -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 24px, #000 calc(100% - 24px), transparent 100%); mask-image: linear-gradient(90deg, transparent 0, #000 24px, #000 calc(100% - 24px), transparent 100%); }
  }

  /* Phone-specific: get to a service photo within the first screen,
     let the next card peek in clearly, move arrows under the slider */
  @media (max-width: 640px) {
    .services { padding: 0 0 90px; }
    .services-head { padding: 48px 16px 20px; gap: 10px; }
    .services-head .overline { margin-bottom: 12px; }
    .services-head h2 { font-size: 26px; line-height: 1.18; }
    .services-head-right { flex-direction: column; align-items: flex-start; gap: 14px; }
    .services-head p {
      font-size: 13.5px;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .services-head .slider-nav { display: none; }

    .slider-nav-mobile {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-top: 18px;
    }

    .slider-track { padding: 4px 16px; gap: 14px; }
    .service-card { width: 70vw; height: 340px; border-radius: 12px; }
    .service-card h3 { font-size: 17px; }
    .slider-viewport { -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 12px, #000 calc(100% - 12px), transparent 100%); mask-image: linear-gradient(90deg, transparent 0, #000 12px, #000 calc(100% - 12px), transparent 100%); }
  }

  .slider-nav-mobile { display: none; }

  @media (prefers-reduced-motion: reduce) {
    .slider-track { transition: none !important; }
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    header { padding: 0 24px; }
    nav.links { display: none; }
    .menu-btn { display: block; }
    .hero { padding: 140px 20px 60px; }
    .portfolio { padding: 0 20px 80px; }

  }

  /* Hybrid mobile layout: most photos run full-width in a single
     column for impact; every so often two are paired side-by-side
     for rhythm/variety. Built by JS below. */
  .masonry {
    display: none;
    flex-direction: column;
    gap: 16px;
  }

  .pair-row {
    display: flex;
    gap: 12px;
  }

  .pair-row .tile {
    flex: 1;
    min-width: 0;
  }

  .masonry .tile {
    grid-column: unset;
    grid-row: unset;
    width: 100%;
  }

  .masonry .tile img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 900px) {
    .grid.js-hidden { display: none; }
    .masonry.js-active { display: flex; }
  }

  /* ---------- FIXED BACKGROUND VIDEO (between About and Services) ----------
     Sits fixed behind everything. Stays completely still while the page
     scrolls. About and Services both get an opaque background + are
     promoted to positioned elements with z-index above the video, so they
     cover it. The .video-reveal-gap between them has no background, so
     while IT scrolls through the viewport, the fixed video shows through. */
  .bg-video-fixed {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100dvh;
    z-index: 0;
    overflow: hidden;
  }
  .bg-video-fixed video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-reveal-gap {
    position: relative;
    z-index: 1;
    height: 50dvh;
    background: transparent;
    pointer-events: none;
  }

  /* ---------- ABOUT ---------- */
  .about-section {
    position: relative;
    z-index: 1;
    background: var(--cream);
    display: flex;
    width: 100%;
    max-width: 100vw;
    padding: 100px 48px 120px;
    align-items: stretch;
  }

  .about-section .col-left {
    width: 62%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-right: 5vw;
  }

  .about-section .overline {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: var(--gray);
    text-transform: uppercase;
    margin-bottom: 30px;
  }

  .about-section .main-heading {
    font-family: 'Fraunces', serif;
    font-weight: 400;
    font-size: clamp(32px, 6vw, 64px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .about-section .nowrap { white-space: nowrap; display: block; overflow: hidden; }

  .about-section .col-right {
    width: 38%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 4px;
  }

  .about-section .description {
    font-size: 16px;
    line-height: 1.85;
    color: var(--gray);
    font-weight: 400;
    border-left: 1px solid rgba(29,26,22,0);
    padding-left: 5vw;
    transition: border-left-color 0.8s ease 0.6s;
  }

  .about-section.is-visible .description { border-left-color: var(--line); }

  .description [data-su] {
    display: block;
    margin-bottom: 16px;
  }
  .description [data-su]:last-child { margin-bottom: 0; }

  /* Line-mask reveal: each heading line slides up from behind an
     overflow-hidden mask, staggered line by line */
  .about-line-mask { display: block; overflow: hidden; }
  .about-line-inner {
    display: block;
    transform: translateY(105%);
    transition: transform 0.7s cubic-bezier(0.22,1,0.36,1);
  }
  .about-section.is-visible .about-line-inner { transform: translateY(0); }
  .about-section.is-visible .about-line-mask:nth-child(1) .about-line-inner { transition-delay: 0s; }
  .about-section.is-visible .about-line-mask:nth-child(2) .about-line-inner { transition-delay: 0.12s; }
  .about-section.is-visible .about-line-mask:nth-child(3) .about-line-inner { transition-delay: 0.24s; }
  .about-section.is-visible .about-line-mask:nth-child(4) .about-line-inner { transition-delay: 0.36s; }

  /* Generic staggered fade-up reveal, used on the overline and each
     description line via [data-su] + an inline transition-delay */
  [data-su] { opacity: 0; transform: translateY(24px); transition: opacity 0.65s ease, transform 0.65s ease; }
  [data-su].is-visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 900px) {
    .about-section { flex-direction: column; padding: 70px 20px 90px; }
    .about-section .col-left {
      width: 100%;
      padding-right: 0;
      padding-bottom: 32px;
      margin-bottom: 32px;
      border-bottom: 1px solid var(--line);
    }
    .about-section .col-right { width: 100%; justify-content: flex-start; }
    .about-section .description { font-size: 15px; line-height: 1.7; border-left: none; padding-left: 0; }
    .about-section .overline { font-size: 11px; margin-bottom: 20px; }
    .about-section .main-heading { font-size: 38px; line-height: 1.12; }
    .about-section .nowrap { white-space: normal; }
  }

  :focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ---------- TESTIMONIALS (merged from sample1.html, classes namespaced with tc- to avoid collisions) ---------- */
  .testimonials-section{
    position:relative;
    z-index:1;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    font-family:Inter,Arial,sans-serif;
    background:var(--cream);
    padding:100px 10px 130px;
    gap:28px;
    overflow-x:hidden;
  }
  .tc-wrap{
    position:relative;width:100%;max-width:900px;height:420px;
    perspective:1600px;
  }
  .tc-card{
    position:absolute;top:50%;left:50%;width:340px;padding:30px 28px;
    background:var(--cream);
    border:1px solid rgba(255,255,255,.16);
    border-radius:22px;color:#fff;
    box-shadow:
