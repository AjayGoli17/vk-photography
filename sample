      d.innerHTML=`<div class="tc-quote" aria-hidden="true">&#10078;</div>
        <blockquote>${x.quote}</blockquote>
        <div class="tc-user">
          <div><div class="tc-name">${x.name}</div><div class="tc-role">${x.role}</div></div>
        </div>`;
      w.appendChild(d);
      d.addEventListener('click',()=>{ c=i; draw(); resetTimer(); });
