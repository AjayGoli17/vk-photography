diff --git a/css/custom-additions.css b/css/custom-additions.css
new file mode 100644
index 0000000..2222222
--- /dev/null
+++ b/css/custom-additions.css
@@ -0,0 +1,50 @@
+.logo-img {
+  height: 36px;
+  width: auto;
+  display: block;
+}
+
+.footer-col-contact .contact-card,
+.footer-col .contact-card {
+  background: #000;
+  border: 1px solid rgba(255, 255, 255, 0.15);
+  border-radius: 16px;
+  padding: 20px;
+  display: flex;
+  flex-direction: column;
+  gap: 16px;
+}
+
+.contact-row {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  color: #fff;
+  font-size: 0.95rem;
+}
+
+.contact-row svg {
+  width: 18px;
+  height: 18px;
+  flex-shrink: 0;
+}
+
+.contact-row a {
+  color: #fff;
+  text-decoration: none;
+}
+
+.contact-directions-btn {
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  gap: 8px;
+  background: #fff;
+  color: #000;
+  border-radius: 999px;
+  padding: 12px 20px;
+  font-weight: 600;
+  text-decoration: none;
+  margin-top: 4px;
+}
+
+.contact-directions-btn svg {
+  width: 16px;
+  height: 16px;
+}
